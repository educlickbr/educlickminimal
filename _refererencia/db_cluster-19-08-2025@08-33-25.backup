--
-- Name: view_cmct_ciclos_completo; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.view_cmct_ciclos_completo WITH (security_invoker='on') AS
 WITH horarios_agrupados AS (
         SELECT c_1.id AS id_ciclo,
            count(DISTINCT cd_1.dia_semana) AS qtd_dias,
            round(sum((EXTRACT(epoch FROM (ch_1.hora_fim - ch_1.hora_inicio)) / (3600)::numeric)), 2) AS carga_horaria_semanal
           FROM ((public.cmct_ciclos c_1
             LEFT JOIN public.cmct_ciclos_dias cd_1 ON ((cd_1.id_ciclo = c_1.id)))
             LEFT JOIN public.cmct_ciclos_horarios ch_1 ON ((ch_1.id_ciclo_dia = cd_1.id)))
          GROUP BY c_1.id
        )
 SELECT c.id AS id_ciclo,
    c.id_modulo,
    c.codigo_interno,
    c.data_inicio,
    c.data_fim,
    c.ativo,
    c.criado_em,
    c.atualizado_em,
    c.criado_por,
    c.modificado_por,
    cd.id AS id_ciclo_dia,
    cd.dia_semana,
    ch.id AS id_ciclo_horario,
    to_char((ch.hora_inicio)::interval, 'HH24'::text) AS hora_ini,
    to_char((ch.hora_inicio)::interval, 'MI'::text) AS minuto_ini,
    to_char((ch.hora_fim)::interval, 'HH24'::text) AS hora_fim,
    to_char((ch.hora_fim)::interval, 'MI'::text) AS minuto_fim,
    (ceil(((((c.data_fim - c.data_inicio) + 1))::numeric / 7.0)))::integer AS qtd_semanas,
    ha.qtd_dias,
    ha.carga_horaria_semanal,
    round((ha.carga_horaria_semanal / (NULLIF(ha.qtd_dias, 0))::numeric), 2) AS duracao_aula
   FROM (((public.cmct_ciclos c
     LEFT JOIN public.cmct_ciclos_dias cd ON ((cd.id_ciclo = c.id)))
     LEFT JOIN public.cmct_ciclos_horarios ch ON ((ch.id_ciclo_dia = cd.id)))
     LEFT JOIN horarios_agrupados ha ON ((ha.id_ciclo = c.id)));


ALTER TABLE public.view_cmct_ciclos_completo OWNER TO postgres;

--
-- Name: view_cmct_ciclos_modulo; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.view_cmct_ciclos_modulo WITH (security_invoker='on') AS
 SELECT c.id AS id_ciclo,
    c.id_modulo,
    m.nome AS nome_modulo,
    m.codigo_interno AS codigo_interno_modulo,
    m.nivel AS nivel_modulo,
    m.carga_horaria,
    c.codigo_interno AS codigo_interno_ciclo,
    c.turno,
    c.data_inicio,
    c.data_fim,
    c.carga_horaria_ciclo,
    c.ativo,
    c.criado_em,
    c.atualizado_em,
    c.criado_por,
    c.modificado_por,
    c.dias_adicionais,
    c.aulas_por_dia
   FROM (public.cmct_ciclos c
     JOIN public.cmct_modulos m ON ((c.id_modulo = m.id)));


ALTER TABLE public.view_cmct_ciclos_modulo OWNER TO postgres;

