--
-- Name: vw_user_perguntas_paginas; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.vw_user_perguntas_paginas WITH (security_invoker='on') AS
 SELECT DISTINCT user_perguntas.nome_pagina,
    user_perguntas.numero_pagina
   FROM public.user_perguntas
  WHERE (user_perguntas.paginado IS TRUE)
  ORDER BY user_perguntas.numero_pagina;


ALTER TABLE public.vw_user_perguntas_paginas OWNER TO postgres;

