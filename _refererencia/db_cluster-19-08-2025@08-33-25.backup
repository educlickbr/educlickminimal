--
-- Name: feriados; Type: TABLE; Schema: public; Owner: postgres
--

CREATE TABLE public.feriados (
    id uuid DEFAULT gen_random_uuid() NOT NULL,
    nome text NOT NULL,
    data date NOT NULL,
    dia_semana text GENERATED ALWAYS AS (
CASE EXTRACT(dow FROM data)
    WHEN 0 THEN 'Domingo'::text
    WHEN 1 THEN 'Segunda-feira'::text
    WHEN 2 THEN 'Terça-feira'::text
    WHEN 3 THEN 'Quarta-feira'::text
    WHEN 4 THEN 'Quinta-feira'::text
    WHEN 5 THEN 'Sexta-feira'::text
    WHEN 6 THEN 'Sábado'::text
    ELSE NULL::text
END) STORED,
    emenda boolean GENERATED ALWAYS AS (
CASE
    WHEN (EXTRACT(dow FROM data) = (4)::numeric) THEN true
    WHEN (EXTRACT(dow FROM data) = (2)::numeric) THEN true
    ELSE false
END) STORED,
    obs text
);


ALTER TABLE public.feriados OWNER TO postgres;

