    NULL::jsonb AS modulos,
    NULL::jsonb AS componentes;


ALTER TABLE public.view_cmct_programa_detalhes OWNER TO postgres;

--
-- Name: view_curso_modulo; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.view_curso_modulo WITH (security_invoker='on') AS
 SELECT cmct_curso_modulo.id AS id_curso_modulo,
    c.id AS id_curso,
    c.nome AS nome_curso,
    c.codigo_interno AS codigo_curso,
    m.id AS id_modulo,
    m.nome AS nome_modulo,
    m.codigo_interno AS codigo_modulo
   FROM ((public.cmct_curso_modulo
     JOIN public.cmct_cursos c ON ((cmct_curso_modulo.id_curso = c.id)))
     JOIN public.cmct_modulos m ON ((cmct_curso_modulo.id_modulo = m.id)))
  WHERE ((c.ativo IS TRUE) AND (m.ativo IS TRUE));


ALTER TABLE public.view_curso_modulo OWNER TO postgres;

--
-- Name: view_feriados_e_emendas; Type: VIEW; Schema: public; Owner: postgres
--

CREATE VIEW public.view_feriados_e_emendas WITH (security_invoker='on') AS
 SELECT feriados.id,
    feriados.nome,
    feriados.data,
    'feriado'::text AS tipo,
    feriados.dia_semana,
    feriados.obs
   FROM public.feriados
UNION ALL
 SELECT gen_random_uuid() AS id,
    ('Emenda de '::text || feriados.nome) AS nome,
    (feriados.data - '1 day'::interval) AS data,
    'emenda'::text AS tipo,
    'Segunda-feira'::text AS dia_semana,
    ('Emenda do feriado '::text || feriados.nome) AS obs
   FROM public.feriados
  WHERE (EXTRACT(dow FROM feriados.data) = (2)::numeric)
UNION ALL
 SELECT gen_random_uuid() AS id,
    ('Emenda de '::text || feriados.nome) AS nome,
    (feriados.data + '1 day'::interval) AS data,
    'emenda'::text AS tipo,
    'Sexta-feira'::text AS dia_semana,
    ('Emenda do feriado '::text || feriados.nome) AS obs
   FROM public.feriados
  WHERE (EXTRACT(dow FROM feriados.data) = (4)::numeric)
UNION ALL
 SELECT gen_random_uuid() AS id,
    ('Emenda de '::text || feriados.nome) AS nome,
    (feriados.data + '2 days'::interval) AS data,
    'emenda'::text AS tipo,
    'Sábado'::text AS dia_semana,
    ('Emenda do feriado '::text || feriados.nome) AS obs
   FROM public.feriados
  WHERE (EXTRACT(dow FROM feriados.data) = (4)::numeric)
UNION ALL
 SELECT gen_random_uuid() AS id,
    ('Emenda de '::text || feriados.nome) AS nome,
    (feriados.data + '1 day'::interval) AS data,
    'emenda'::text AS tipo,
    'Sábado'::text AS dia_semana,
    ('Emenda do feriado '::text || feriados.nome) AS obs
   FROM public.feriados
  WHERE (EXTRACT(dow FROM feriados.data) = (5)::numeric);


ALTER TABLE public.view_feriados_e_emendas OWNER TO postgres;

--
-- Name: vw_user_perguntas_arquivo_sensivel_ids; Type: VIEW; Schema: public; Owner: postgres
