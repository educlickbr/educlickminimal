--
-- Name: objects Admin pode ver tudo; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Admin pode ver tudo" ON storage.objects FOR SELECT USING (((bucket_id = 'arquivosusers'::text) AND ((auth.jwt() ->> 'role_user'::text) = 'admin'::text)));


--
-- Name: objects User pode fazer upload (insert) no próprio bucket; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "User pode fazer upload (insert) no próprio bucket" ON storage.objects FOR INSERT WITH CHECK (((bucket_id = 'arquivosusers'::text) AND (owner = auth.uid())));


--
-- Name: objects Users can delete their own files; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Users can delete their own files" ON storage.objects FOR DELETE USING (((bucket_id = 'arquivosusers'::text) AND (owner = auth.uid())));


--
-- Name: objects Users can select their own files; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Users can select their own files" ON storage.objects FOR SELECT USING (((bucket_id = 'arquivosusers'::text) AND (name ~~ (auth.uid() || '/%'::text))));


--
-- Name: objects Users can update their own files; Type: POLICY; Schema: storage; Owner: supabase_storage_admin
--

CREATE POLICY "Users can update their own files" ON storage.objects FOR UPDATE USING (((bucket_id = 'arquivosusers'::text) AND (owner = auth.uid())));


