--
-- Name: view_cmct_programa_detalhes _RETURN; Type: RULE; Schema: public; Owner: postgres
--

CREATE OR REPLACE VIEW public.view_cmct_programa_detalhes WITH (security_invoker='on') AS
 SELECT p.id AS id_programa,
    p.nome AS nome_programa,
    p.codigo_interno,
    p.descricao AS descricao_programa,
    c.id AS id_curso,
    c.nome AS nome_curso,
    c.imagem AS imagem_curso,
    c.descricao_curta,
    c.descricao_longa,
    count(DISTINCT pc.id_ciclo) AS qtd_ciclos,
    jsonb_agg(DISTINCT ci.id) FILTER (WHERE (ci.id IS NOT NULL)) AS ids_ciclos,
    LEAST(((min(ci.data_inicio))::timestamp without time zone)::timestamp with time zone, min(ca.data_inicio)) AS data_inicio,
    GREATEST(((max(ci.data_fim))::timestamp without time zone)::timestamp with time zone, max(ca.data_fim)) AS data_fim,
    jsonb_agg(DISTINCT jsonb_build_object('dia_semana', cd.dia_semana, 'hora_inicio', ch.hora_inicio, 'hora_fim', ch.hora_fim)) FILTER (WHERE (cd.id IS NOT NULL)) AS dias_horarios,
    jsonb_agg(DISTINCT ci.turno) FILTER (WHERE (ci.turno IS NOT NULL)) AS turnos,
    jsonb_agg(DISTINCT ci.codigo_interno) FILTER (WHERE (ci.codigo_interno IS NOT NULL)) AS codigos_ciclos,
    jsonb_agg(DISTINCT jsonb_build_object('id', m.id, 'nome', m.nome, 'codigo_interno', m.codigo_interno)) FILTER (WHERE (m.id IS NOT NULL)) AS modulos,
    jsonb_agg(DISTINCT jsonb_build_object('id', comp.id, 'nome', comp.nome, 'carga_horaria', comp.carga_horaria)) FILTER (WHERE (comp.id IS NOT NULL)) AS componentes
   FROM ((((((((public.cmct_programas p
     JOIN public.cmct_cursos c ON ((p.id_curso = c.id)))
     LEFT JOIN public.cmct_programa_ciclo pc ON ((pc.id_programa = p.id)))
     LEFT JOIN public.cmct_ciclos ci ON ((ci.id = pc.id_ciclo)))
     LEFT JOIN public.cmct_calendario_aulas ca ON ((ca.id_programa = p.id)))
     LEFT JOIN public.cmct_ciclos_dias cd ON ((cd.id_ciclo = ci.id)))
     LEFT JOIN public.cmct_ciclos_horarios ch ON ((ch.id_ciclo_dia = cd.id)))
     LEFT JOIN public.cmct_modulos m ON ((m.id = ci.id_modulo)))
     LEFT JOIN public.cmct_componentes comp ON ((comp.id_modulo = m.id)))
  GROUP BY p.id, c.id;


