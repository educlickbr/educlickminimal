    NULL::text AS imagem_curso,
    NULL::text AS descricao_curta,
    NULL::text AS descricao_longa,
    NULL::bigint AS qtd_ciclos,
    NULL::jsonb AS ids_ciclos,
    NULL::timestamp with time zone AS data_inicio,
    NULL::timestamp with time zone AS data_fim,
    NULL::jsonb AS dias_horarios,
    NULL::jsonb AS turnos,
